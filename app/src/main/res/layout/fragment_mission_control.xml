<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MISSION CONTROL"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose two healthy crew members and assign a tactic to each one."
        android:textColor="#8892B0"
        android:textSize="12sp"
        android:layout_marginBottom="12dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#1C2235"
        app:cardCornerRadius="10dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/tv_threat_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Active Threat"
            android:textColor="#FF5252"
            android:textStyle="bold"
            android:textSize="15sp"
            android:padding="16dp"/>

    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Crew Member 1:"
        android:textColor="#8892B0"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinner_crew_1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1C2235"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_tactic_1"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#151A28"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Crew Member 2:"
        android:textColor="#8892B0"
        android:layout_marginBottom="4dp"/>

    <Spinner
        android:id="@+id/spinner_crew_2"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#1C2235"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinner_tactic_2"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="#151A28"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/btn_launch_mission"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="LAUNCH MISSION"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_cancel_mission"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="CANCEL"
            android:backgroundTint="#FF5252"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>

    </LinearLayout>

    <Button
        android:id="@+id/btn_resolve_mission"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="RESOLVE MISSION"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:textStyle="bold"/>

    <ScrollView
        android:id="@+id/scroll_mission_log"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D1117"
        android:padding="4dp">

        <TextView
            android:id="@+id/tv_mission_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mission log will appear here..."
            android:textColor="#8892B0"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="8dp"/>

    </ScrollView>

</LinearLayout>
